generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  subdomain  String   @unique
  address    String?
  phone      String?
  email      String?
  logo       String?
  isActive   Boolean  @default(false)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users              User[]
  students           Student[]
  teachers           Teacher[]
  classes            Class[]
  subjects           Subject[]
  enrollments        Enrollment[]
  attendance         Attendance[]
  exams              Exam[]
  grades             Grade[]
  feeStructures      FeeStructure[]
  feePayments        FeePayment[]
  timetables         Timetable[]
  announcements      Announcement[]
  aiConversations    AiConversation[]
  departments        Department[]
  libraryBooks       LibraryBook[]
  bookCheckouts      BookCheckout[]
  scienceApparatus   ScienceApparatus[]
  apparatusLogs      ApparatusLog[]
  subjectPerformance SubjectPerformance[]
  notifications      Notification[]
  departmentLogs     DepartmentLog[]
  boardMembers       BoardMember[]
  boardMeetings      BoardMeeting[]
  meetingAgendaItems MeetingAgendaItem[]
  meetingMinutes     MeetingMinute[]
  meetingRecordings  MeetingRecording[]
  boardSuggestions   BoardSuggestion[]
}

model Department {
  id        String   @id @default(cuid())
  name      String
  slug      String
  type      String   // academic, lab, library, bursar, computer_lab
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())

  users         User[]
  notifications Notification[]

  @@unique([slug, schoolId])
  @@index([schoolId])
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified DateTime?
  name          String
  password      String?
  role          String   @default("school_admin") // super_admin, school_admin, bursar, librarian, lab_technician, computer_lab, department_head, class_teacher, teacher
  image         String?
  mfaEnabled    Boolean  @default(false)
  mfaSecret     String?
  failedLoginCount Int   @default(0)
  lockedUntil   DateTime?
  schoolId      String?
  school        School?  @relation(fields: [schoolId], references: [id])
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts          Account[]
  sessions          Session[]
  announcements     Announcement[]
  feePayments       FeePayment[]
  teacher           Teacher?              // one-to-one with Teacher profile
  classTeacherOf    Class[]               // classes where this user is class teacher
  sentNotifications Notification[]        @relation("sent_notifications")
  notificationReads NotificationRead[]
  apparatusLogs     ApparatusLog[]
  performanceRecords SubjectPerformance[]
  departmentLogs    DepartmentLog[]
  boardMembership   BoardMember?           // one-to-one board membership
  createdMeetings   BoardMeeting[]         // meetings created by this user
  uploadedRecordings MeetingRecording[]
  @@index([schoolId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  mfaRequired  Boolean  @default(false)
  mfaVerified  Boolean  @default(false)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Teacher {
  id              String   @id @default(cuid())
  employeeNo      String
  firstName       String
  lastName        String
  gender          String?
  phone           String?
  email           String?
  qualification   String?
  specialization  String?
  dateOfBirth     DateTime?
  address         String?
  status          String   @default("active")
  deletedAt       DateTime?
  userId          String?  @unique           // links login account to teacher profile
  user            User?    @relation(fields: [userId], references: [id])
  schoolId        String?
  school          School?  @relation(fields: [schoolId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  classes  Class[]
  subjects Subject[]

  @@unique([employeeNo, schoolId])
  @@index([schoolId])
}

model Student {
  id            String   @id @default(cuid())
  admissionNo   String
  firstName     String
  lastName      String
  gender        String // male, female
  dateOfBirth   DateTime?
  address       String?
  phone         String?
  email         String?
  guardianName  String?
  guardianPhone String?
  guardianEmail String?
  status        String   @default("active")
  deletedAt     DateTime?
  schoolId      String?
  school        School?  @relation(fields: [schoolId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  enrollments Enrollment[]
  attendance  Attendance[]
  grades      Grade[]
  feePayments FeePayment[]
  bookCheckouts BookCheckout[]

  @@unique([admissionNo, schoolId])
  @@index([schoolId])
}

model Class {
  id             String   @id @default(cuid())
  name           String
  code           String
  academicYear   String
  capacity       Int?
  teacherId      String?
  teacher        Teacher? @relation(fields: [teacherId], references: [id])
  classTeacherId String?
  classTeacher   User?    @relation(fields: [classTeacherId], references: [id])
  schoolId       String?
  school         School?  @relation(fields: [schoolId], references: [id])
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  enrollments Enrollment[]
  attendance  Attendance[]
  grades      Grade[]
  timetable   Timetable[]
  subjects    Subject[]
  performance SubjectPerformance[]

  @@unique([code, schoolId])
  @@index([schoolId])
}

model Subject {
  id        String   @id @default(cuid())
  name      String
  code      String
  category  String?
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  classId   String?
  class     Class?   @relation(fields: [classId], references: [id])
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())

  grades      Grade[]
  timetable   Timetable[]
  performance SubjectPerformance[]

  @@unique([code, schoolId])
  @@index([schoolId])
}

model Enrollment {
  id           String   @id @default(cuid())
  studentId    String
  classId      String
  academicYear String
  date         DateTime @default(now())
  status       String   @default("active")
  schoolId     String?
  school       School?  @relation(fields: [schoolId], references: [id])

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, academicYear])
  @@index([schoolId])
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  classId   String
  date      DateTime
  status    String // present, absent, late, excused
  remarks   String?
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, date])
  @@index([schoolId])
}

model Exam {
  id          String   @id @default(cuid())
  name        String
  term        String
  academicYear String
  startDate   DateTime
  endDate     DateTime
  description String?
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())

  grades      Grade[]
  performance SubjectPerformance[]
  @@index([schoolId])
}

model Grade {
  id        String   @id @default(cuid())
  studentId String
  subjectId String
  examId    String
  classId   String?
  score     Float?
  grade     String?
  remarks   String?
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  exam    Exam    @relation(fields: [examId], references: [id])
  class   Class?  @relation(fields: [classId], references: [id])

  @@unique([studentId, subjectId, examId])
  @@index([schoolId])
}

model FeeStructure {
  id           String   @id @default(cuid())
  name         String
  amount       Float
  frequency    String   @default("term")
  academicYear String
  classId      String?
  description  String?
  schoolId     String?
  school       School?  @relation(fields: [schoolId], references: [id])
  createdAt    DateTime @default(now())

  payments FeePayment[]
  @@index([schoolId])
}

model FeePayment {
  id             String   @id @default(cuid())
  feeStructureId String
  studentId      String
  userId         String
  amount         Float
  paymentDate    DateTime @default(now())
  method         String   @default("cash")
  transactionRef String?
  term           String
  academicYear   String
  notes          String?
  schoolId       String?
  school         School?  @relation(fields: [schoolId], references: [id])
  createdAt      DateTime @default(now())

  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  @@index([schoolId])
}

model Timetable {
  id        String   @id @default(cuid())
  classId   String
  subjectId String
  dayOfWeek Int
  startTime String
  endTime   String
  room      String?
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  @@index([schoolId])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  priority  String   @default("normal")
  target    String   @default("all")
  classId   String?
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])
  @@index([schoolId])
}

model AiConversation {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
  @@index([schoolId])
}

model LibraryBook {
  id         String   @id @default(cuid())
  title      String
  author     String
  isbn       String?
  publisher  String?
  year       Int?
  quantity   Int      @default(1)
  available  Int      @default(1)
  shelf      String?
  category   String?
  schoolId   String?
  school     School?  @relation(fields: [schoolId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  checkouts  BookCheckout[]
  @@index([schoolId])
}

model BookCheckout {
  id           String    @id @default(cuid())
  bookId       String
  book         LibraryBook @relation(fields: [bookId], references: [id])
  admissionNo  String      // student admission number
  studentName  String?
  checkoutDate DateTime    @default(now())
  dueDate      DateTime
  returnDate   DateTime?
  status       String      @default("active") // active, returned, overdue, lost
  notes        String?
  studentId    String?
  student      Student?    @relation(fields: [studentId], references: [id])
  schoolId     String?
  school       School?     @relation(fields: [schoolId], references: [id])
  createdAt    DateTime    @default(now())
  @@index([schoolId])
}

model ScienceApparatus {
  id            String   @id @default(cuid())
  name          String
  category      String?
  totalQuantity Int      @default(1)
  available     Int      @default(1)
  broken        Int      @default(0)
  lost          Int      @default(0)
  description   String?
  schoolId      String?
  school        School?  @relation(fields: [schoolId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  logs ApparatusLog[]
  @@index([schoolId])
}

model ApparatusLog {
  id           String   @id @default(cuid())
  apparatusId  String
  apparatus    ScienceApparatus @relation(fields: [apparatusId], references: [id])
  action       String   // broken, lost, repaired, restocked, discarded
  quantity     Int
  reportedById String?
  reportedBy   User?    @relation(fields: [reportedById], references: [id])
  notes        String?
  date         DateTime @default(now())
  schoolId     String?
  school       School?  @relation(fields: [schoolId], references: [id])
  @@index([schoolId])
}

model SubjectPerformance {
  id           String   @id @default(cuid())
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id])
  classId      String
  class        Class    @relation(fields: [classId], references: [id])
  examId       String
  exam         Exam     @relation(fields: [examId], references: [id])
  term         String
  academicYear String
  studentCount Int?
  meanScore    Float?
  highestScore Float?
  lowestScore  Float?
  passRate     Float?
  recordedById String?
  recordedBy   User?    @relation(fields: [recordedById], references: [id])
  schoolId     String?
  school       School?  @relation(fields: [schoolId], references: [id])
  createdAt    DateTime @default(now())

  @@unique([subjectId, classId, examId])
  @@index([schoolId])
}

model Notification {
  id                 String   @id @default(cuid())
  title              String
  content            String
  priority           String   @default("normal")
  senderId           String
  sender             User     @relation("sent_notifications", fields: [senderId], references: [id])
  targetRole         String?  // null = all, or specific role
  targetDepartmentId String?
  targetDepartment   Department? @relation(fields: [targetDepartmentId], references: [id])
  link               String?
  schoolId           String?
  school             School?  @relation(fields: [schoolId], references: [id])
  createdAt          DateTime @default(now())

  reads NotificationRead[]
  @@index([schoolId])
}

model NotificationRead {
  id             String   @id @default(cuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  readAt         DateTime @default(now())

  @@unique([notificationId, userId])
}

model DepartmentLog {
  id          String   @id @default(cuid())
  department  String   // department slug or type
  action      String   // what happened
  description String   // details
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  metadata    String?  // JSON string for extra data
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  @@index([schoolId])
}

// ─── BOM / Board of Management ───

model BoardMember {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  role           String   // chairperson, secretary, treasurer, member
  joinedAt       DateTime @default(now())
  isActive       Boolean  @default(true)
  schoolId       String?
  school         School?  @relation(fields: [schoolId], references: [id])

  suggestions    BoardSuggestion[]
  meetingMinutes MeetingMinute[]
  @@index([schoolId])
}

model BoardMeeting {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  startTime   String?
  endTime     String?
  venue       String?
  status      String   @default("scheduled") // scheduled, ongoing, adjourned, completed
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agendaItems    MeetingAgendaItem[]
  minutes        MeetingMinute[]
  recordings     MeetingRecording[]
  suggestions    BoardSuggestion[]
  @@index([schoolId])
}

model MeetingAgendaItem {
  id         String   @id @default(cuid())
  meetingId  String
  meeting    BoardMeeting @relation(fields: [meetingId], references: [id])
  title      String
  description String?
  order      Int
  duration   Int?     // minutes
  schoolId   String?
  school     School?  @relation(fields: [schoolId], references: [id])
  createdAt  DateTime @default(now())

  minutes    MeetingMinute[]
  @@index([schoolId])
}

model MeetingMinute {
  id              String   @id @default(cuid())
  meetingId       String
  meeting         BoardMeeting @relation(fields: [meetingId], references: [id])
  agendaItemId    String?
  agendaItem      MeetingAgendaItem? @relation(fields: [agendaItemId], references: [id])
  content         String   @default("")
  aiSummary       String?  // AI-generated summary
  aiProofread     String?  // AI-proofread version
  recordedById    String
  recordedBy      BoardMember @relation(fields: [recordedById], references: [id])
  schoolId        String?
  school          School?  @relation(fields: [schoolId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([schoolId])
}

model MeetingRecording {
  id        String   @id @default(cuid())
  meetingId String
  meeting   BoardMeeting @relation(fields: [meetingId], references: [id])
  type      String   // voice, photo, document
  fileUrl   String   // path to file (stored locally with size limits)
  fileSize  Int?     // bytes
  duration  Int?     // seconds for voice recordings
  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
  schoolId String?
  school   School?  @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
  @@index([schoolId])
}

model BoardSuggestion {
  id          String   @id @default(cuid())
  boardMemberId String
  boardMember   BoardMember @relation(fields: [boardMemberId], references: [id])
  title       String
  content     String
  category    String   @default("general") // general, finance, academics, infrastructure, welfare
  status      String   @default("submitted") // submitted, under_review, adopted, declined
  meetingId   String?  // linked to a meeting if submitted during one
  meeting     BoardMeeting? @relation(fields: [meetingId], references: [id])
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([schoolId])
}
